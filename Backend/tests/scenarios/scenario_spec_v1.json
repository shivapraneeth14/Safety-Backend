{
  "specVersion": "1.0",
  "frozen": true,
  "description": "Scenario Test Specification for Safety App v2.0 — Uncertainty-first collision avoidance system",
  "goldenDataset": ["G-01","G-02","G-03","G-04","G-05","G-06","G-07","G-08","G-09","G-10"],
  "killCriteria": {
    "mapMatching": {
      "goldenScenarios": ["G-03","G-04","G-05"],
      "minAccuracy": 0.85,
      "maxIterations": 3
    },
    "etaRegistry": {
      "goldenScenarios": ["G-01","G-08"],
      "maxAvgErrorMeters": 1.5,
      "maxPercentOver3sError": 20,
      "maxIterations": 2
    },
    "collisionProbability": {
      "goldenScenarios": "ALL",
      "maxFPR": 25,
      "minRecall": 70,
      "maxIterations": 2
    },
    "alertConfidence": {
      "goldenScenarios": "ALL",
      "maxCalibrationError": 15,
      "maxIterations": 2
    },
    "timeSync": {
      "redTeamScenarios": ["RT-02"],
      "maxUndetectedOffsetMs": 200,
      "maxIterations": 2
    }
  },
  "metricsDashboard": {
    "precision": { "target": 90, "unit": "%" },
    "recall": { "target": 85, "unit": "%" },
    "falsePositiveRate": { "target": 10, "unit": "%" },
    "avgWarningTime": { "target": 3, "unit": "s" },
    "confidenceCalibrationError": { "target": 10, "unit": "%" },
    "mapMatchAccuracy": { "target": 95, "unit": "%" },
    "etaErrorRMS": { "target": 1.5, "unit": "s" },
    "wsLatencyP50": { "target": 50, "unit": "ms" },
    "wsLatencyP95": { "target": 150, "unit": "ms" },
    "wsLatencyP99": { "target": 300, "unit": "ms" }
  },
  "scenarios": {
    "golden": [
      {
        "id": "G-01",
        "group": "A",
        "name": "Head-on approach",
        "description": "Two vehicles approaching each other on the same road, same lane",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_kmh": 40, "pos_m": [0, 0] },
          { "id": "B", "road": "road_1", "heading": 270, "speed_kmh": 35, "pos_m": [100, 0] }
        ],
        "expected": {
          "alert": true,
          "severity": "critical",
          "minConfidence": 0.8,
          "minLeadTimeSeconds": 3,
          "type": "predicted_collision"
        }
      },
      {
        "id": "G-02",
        "group": "A",
        "name": "Blind junction",
        "description": "Two vehicles approaching a T-junction with building blocking line-of-sight",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_kmh": 30, "junction_distance_m": 40, "tags": { "approaching_junction": true } },
          { "id": "B", "road": "road_2", "heading": 0, "speed_kmh": 25, "junction_distance_m": 35, "tags": { "approaching_junction": true } }
        ],
        "env": { "junction_type": "t_junction", "blind": true },
        "expected": {
          "alert": true,
          "severity": "critical",
          "minConfidence": 0.7,
          "minLeadTimeSeconds": 2,
          "type": "turn_collision"
        }
      },
      {
        "id": "G-03",
        "group": "B",
        "name": "Parallel roads (must NOT alert)",
        "description": "Two vehicles on parallel roads with no connecting byways — no collision possible",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_kmh": 40, "pos_m": [0, 0] },
          { "id": "B", "road": "road_2", "heading": 90, "speed_kmh": 30, "pos_m": [0, 15], "tags": { "parallel_road": true, "no_connection": true } }
        ],
        "expected": {
          "alert": false
        }
      },
      {
        "id": "G-04",
        "group": "B",
        "name": "Flyover (must NOT alert)",
        "description": "Vehicle on flyover bridge, vehicle on surface road directly below — vertical separation",
        "vehicles": [
          { "id": "A", "road": "road_flyover", "heading": 90, "speed_kmh": 40, "pos_m": [0, 0], "tags": { "layer": 1, "bridge": true } },
          { "id": "B", "road": "road_surface", "heading": 90, "speed_kmh": 30, "pos_m": [0, 0], "tags": { "layer": 0, "tunnel": false } }
        ],
        "env": { "vertical_separation_m": 8 },
        "expected": {
          "alert": false
        }
      },
      {
        "id": "G-05",
        "group": "C",
        "name": "GPS drift 15m from road",
        "description": "Vehicle GPS shows position 15m off the actual road — map matching must snap back",
        "vehicles": [
          { "id": "A", "true_road": "road_1", "heading": 90, "speed_kmh": 40, "true_pos_m": [0, 0], "gps_offset_m": [0, 15] }
        ],
        "expected": {
          "alert": false,
          "mapMatchConfidence": { "min": 0.7 },
          "snappedRoad": "road_1",
          "gpsRejected": false
        }
      },
      {
        "id": "G-06",
        "group": "A",
        "name": "Wrong direction",
        "description": "Vehicle traveling opposite to traffic on same road",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_kmh": 30, "pos_m": [0, 0] },
          { "id": "B", "road": "road_1", "heading": 270, "speed_kmh": 25, "pos_m": [80, 0] }
        ],
        "env": { "majority_heading": 90 },
        "expected": {
          "alert": true,
          "severity": "critical",
          "type": "wrong_direction",
          "minConfidence": 0.7
        }
      },
      {
        "id": "G-07",
        "group": "A",
        "name": "Rear-end sudden braking",
        "description": "Leader vehicle brakes hard, follower approaching too fast",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_history_kmh": [40, 35, 25, 15, 10], "speed_kmh": 10, "pos_m": [20, 0] },
          { "id": "B", "road": "road_1", "heading": 90, "speed_kmh": 45, "pos_m": [0, 0] }
        ],
        "expected": {
          "alert": true,
          "severity": "high",
          "type": "rear_end",
          "minConfidence": 0.7,
          "minLeadTimeSeconds": 1.5
        }
      },
      {
        "id": "G-08",
        "group": "A",
        "name": "Merge conflict",
        "description": "Vehicle on main road, vehicle merging from on-ramp",
        "vehicles": [
          { "id": "A", "road": "road_main", "heading": 90, "speed_kmh": 50, "pos_m": [0, 0] },
          { "id": "B", "road": "road_onramp", "heading": 80, "speed_kmh": 40, "merge_distance_m": 60, "pos_m": [40, -10] }
        ],
        "env": { "merge_point_m": 60 },
        "expected": {
          "alert": true,
          "severity": "high",
          "minLeadTimeSeconds": 2,
          "minConfidence": 0.6
        }
      },
      {
        "id": "G-09",
        "group": "C",
        "name": "Stale vehicle detection",
        "description": "Vehicle B stops sending data — system must increase uncertainty and not trigger critical alerts",
        "vehicles": [
          { "id": "A", "road": "road_1", "heading": 90, "speed_kmh": 40, "pos_m": [0, 0] },
          { "id": "B", "road": "road_1", "heading": 90, "speed_kmh": 40, "pos_m": [50, 0], "last_update_seconds_ago": 7 }
        ],
        "expected": {
          "alert": false,
          "staleClassification": "stale",
          "predictionUncertaintyMultiplier": { "min": 2.0 }
        }
      },
      {
        "id": "G-10",
        "group": "C",
        "name": "OSM road missing",
        "description": "Vehicle on newly built road not in OSM — system enters free-space mode without crashing",
        "vehicles": [
          { "id": "A", "road": null, "heading": 90, "speed_kmh": 30, "pos_m": [0, 0], "tags": { "osm_missing": true } }
        ],
        "expected": {
          "alert": false,
          "freeSpaceMode": true,
          "roadConfidence": 0,
          "noCrash": true
        }
      }
    ],
